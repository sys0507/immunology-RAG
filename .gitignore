# =============================================================================
# ImmunoBiology RAG — .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# PDF source files — copyrighted, download separately
# ---------------------------------------------------------------------------
data/raw/*.pdf
data/raw/*.PDF

# ---------------------------------------------------------------------------
# Generated data — rebuilt by running the pipeline
# ---------------------------------------------------------------------------
data/processed/
data/train/
data/english_stopwords.txt
# Diagnostic report files generated by build_index.py
data/index_report.txt
data/pdf_layout_report.txt
# Incomplete downloads (.crdownload = Chrome partial file)
*.crdownload

# ---------------------------------------------------------------------------
# Downloaded model weights — large binary files, download via huggingface-cli
# ---------------------------------------------------------------------------
models/

# ---------------------------------------------------------------------------
# Pipeline outputs — generated at runtime
# ---------------------------------------------------------------------------
outputs/vectorstore/
outputs/diagnostics/
outputs/models/
outputs/reranker_eval/
outputs/llm_eval/
outputs/system_eval/

# ---------------------------------------------------------------------------
# External training frameworks — cloned separately during setup
# ---------------------------------------------------------------------------
LLaMA-Factory/
RAG-Retrieval/

# ---------------------------------------------------------------------------
# Python cache and compiled files
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.conda/

# ---------------------------------------------------------------------------
# Jupyter notebooks
# ---------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints

# ---------------------------------------------------------------------------
# Environment and secrets
# ---------------------------------------------------------------------------
.env
.env.*
*.key
secrets.yaml

# ---------------------------------------------------------------------------
# IDE and editor files
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Claude Code internal files
# ---------------------------------------------------------------------------
.claude/

# ---------------------------------------------------------------------------
# Logs and temporary files
# ---------------------------------------------------------------------------
logs/
*.log
*.tmp
*.temp
/var/log/
nohup.out

# ---------------------------------------------------------------------------
# Build artifacts
# ---------------------------------------------------------------------------
*.egg-info/
dist/
build/
*.egg
.eggs/
*.whl

# ---------------------------------------------------------------------------
# TensorBoard event files (large, regenerated during training)
# ---------------------------------------------------------------------------
runs/
events.out.tfevents.*

# ---------------------------------------------------------------------------
# Miscellaneous
# ---------------------------------------------------------------------------
task.txt
immunology_rag_guide_cn.md
scripts/fix_semantic_chunk.py
